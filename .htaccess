RewriteEngine On
RewriteBase /KTI/

# Don't redirect admin directory
RewriteCond %{REQUEST_URI} !^/KTI/admin/
# Don't redirect dashboard directory
RewriteCond %{REQUEST_URI} !^/KTI/dashboard/
# Don't redirect if already in public
RewriteCond %{REQUEST_URI} !^/KTI/public/
# Redirect everything else to public folder
RewriteRule ^(.*)$ public/$1 [L]
