RewriteEngine On

# Works when the site lives in a subdirectory (e.g. http://localhost/KTI/) — match path segments, not ^/dashboard/.
# Pass through these trees unchanged (they live outside public/).
RewriteCond %{REQUEST_URI} /admin/ [NC,OR]
RewriteCond %{REQUEST_URI} /dashboard/ [NC,OR]
RewriteCond %{REQUEST_URI} /public/
RewriteRule ^ - [L]

# Front controller and static site live under public/
RewriteRule ^(.*)$ public/$1 [L]
